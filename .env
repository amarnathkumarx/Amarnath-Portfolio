# .env - Environment Variables for Portfolio

# ============================================
# EMAILJS CONFIGURATION - REQUIRED FOR CONTACT FORM
# ============================================

# Get these from: https://www.emailjs.com
# 1. Sign up at EmailJS
# 2. Create Email Service (Gmail, Outlook, etc.)
# 3. Create Email Template
# 4. Get your Public Key from Account page

# EmailJS Public Key (from Account page)
REACT_APP_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# EmailJS Service ID (from Email Services page)
REACT_APP_EMAILJS_SERVICE_ID=your_service_id_here

# EmailJS Template ID (from Email Templates page)
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id_here

# ============================================
# CONTACT INFORMATION
# ============================================

# Your contact email (where you want to receive messages)
REACT_APP_CONTACT_EMAIL=amarnathkumar22012004@email.com

# Your phone number (optional)
REACT_APP_CONTACT_PHONE=+91 98765 43210

# Your location
REACT_APP_LOCATION=Bangalore, India

# ============================================
# SOCIAL MEDIA USERNAMES
# ============================================

REACT_APP_GITHUB_USERNAME=amarnathxkumar
REACT_APP_LINKEDIN_USERNAME=amarnathkumarx
REACT_APP_TWITTER_USERNAME=amarnathkumarx

# ============================================
# PRODUCTION URL (for meta tags)
# ============================================

REACT_APP_SITE_URL=https://amarnath-portfolio.vercel.app